{
  "name": "@karax/mcp",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "@karax/mcp": "./dist/bin.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "postinstall": "node --input-type=module -e \"import('@karax/sdk').then(m=>m.ensureDependencies?.()).catch(()=>{})\" || true"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "@karax/sdk": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
