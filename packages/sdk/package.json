    "@sfc/adapter-react-native": "workspace:*",
    "@sfc/compile-android": "workspace:*",
    "@sfc/compile-flutter": "workspace:*",
    "@sfc/compile-ios": "workspace:*",
    "@sfc/compile-react-native": "workspace:*",
    "@sfc/core": "workspace:*",
